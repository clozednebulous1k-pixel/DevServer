# Firebase (cliente - publico no bundle)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (servidor apenas - NUNCA commitar chaves reais)
# Opcao recomendada: cole o JSON inteiro da service account (uma linha) em producao/Vercel.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Alternativa ao JSON completo:
# FIREBASE_ADMIN_PROJECT_ID=
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"

# Primeiro admin (somente teste / primeiro deploy): POST /api/admin/bootstrap
# Gere uma string longa aleatoria; NUNCA commite o valor real.
# ADMIN_BOOTSTRAP_SECRET=
