# Firebase (cliente - publico no bundle)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (servidor apenas - NUNCA commitar chaves reais)
# Opcao recomendada: cole o JSON inteiro da service account (uma linha) em producao/Vercel.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Alternativa ao JSON completo:
# FIREBASE_ADMIN_PROJECT_ID=
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"

# Primeiro admin (primeiro deploy): POST /api/admin/bootstrap
# Gere uma string longa aleatoria; NUNCA commite o valor real.
# ADMIN_BOOTSTRAP_SECRET=

# --- Vercel (producao / preview) ---
# Dashboard: Projeto > Settings > Environment Variables
# Marque Production (e Preview se quiser testar branch).
#
# Cliente Firebase (NEXT_PUBLIC_*): copie do Firebase Console > Configuracao do projeto.
#
# FIREBASE_SERVICE_ACCOUNT_JSON: Firebase Console > Contas de servico > Gerar nova chave JSON.
#   Cole o JSON INTEIRO em UMA LINHA no valor da variavel (minifique no jsonlint.com se precisar).
#   OU use as tres variaveis FIREBASE_ADMIN_* abaixo; em private_key use \n entre linhas da chave.
#
# Depois do deploy, crie o primeiro admin UMA VEZ na URL PUBLICA do site (nao localhost):
#   POST https://seu-dominio.vercel.app/api/admin/bootstrap
#   Body JSON: email, password, secret (igual a ADMIN_BOOTSTRAP_SECRET no Vercel)
# PowerShell:
#   Invoke-RestMethod -Uri "https://seu-dominio.vercel.app/api/admin/bootstrap" -Method POST -ContentType "application/json" -Body '{"email":"...","password":"...","secret":"..."}'
# Remova ADMIN_BOOTSTRAP_SECRET no Vercel e redeploy apos criar o admin.
